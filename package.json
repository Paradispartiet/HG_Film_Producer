{
  "name": "hg-film-producer",
  "version": "0.1.0",
  "private": true,
  "description": "A professional TypeScript foundation for HG Film Producer, a full film studio simulator connected to place-based film history.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "build:ui": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.app.json",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/core/*.test.js",
    "preflight:v0.1": "node scripts/preflight-v0.1.mjs",
    "verify:v0.1": "npm run preflight:v0.1 && npm run typecheck && npm test && npm run build:ui",
    "qa:manual": "node scripts/qa-manual.mjs",
    "qa:manual:preview": "node scripts/qa-manual.mjs --preview"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.5.4",
    "vite": "^7.1.7"
  }
}
